# Article Summarizer Agent - Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Required in production
SECRET_KEY=change-me-to-a-long-random-string
GEMINI_API_KEY=

# Summarisation
SUMMARIZATION_METHOD=extractive
SUMMARY_LENGTH=medium
GEMINI_MODEL_ID=gemini-2.5-flash-preview-05-20
GEMINI_TIMEOUT=30

# Web server
PORT=5000
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5000

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW=300
POLL_RATE_LIMIT_MAX=60
POLL_RATE_LIMIT_WINDOW=60
ADMIN_RATE_LIMIT_MAX=10
ADMIN_RATE_LIMIT_WINDOW=300

# Scraping
TIMEOUT_SCRAPING=30
MAX_RETRIES_SCRAPING=3

# Cache & output
CACHE_ENABLED=true
CACHE_TTL=86400
OUTPUT_DIR=outputs

# Logging
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://summarizer:summarizer@localhost:5432/summarizer

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# Celery
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/2
FLOWER_BASIC_AUTH=admin:changeme

# Metrics
METRICS_TOKEN=

# OpenTelemetry (distributed tracing)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=article-summarizer

# JWT authentication
JWT_SECRET_KEY=
JWT_SECRET_V2=
ADMIN_USER=admin
ADMIN_PASSWORD=
JWT_EXPIRES_HOURS=24
JWT_COOKIE_CSRF_PROTECT=true
