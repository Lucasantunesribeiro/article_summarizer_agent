# ─────────────────────────────────────────────────────────────────────────────
# Article Summarizer Agent — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required in production ───────────────────────────────────────────────────

# Flask session secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change-me-to-a-long-random-string

# Google Gemini API key (required for "generative" summarisation method)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Summarisation ─────────────────────────────────────────────────────────────

# Summarisation backend: "extractive" (offline, no key needed) or "generative" (Gemini)
SUMMARIZATION_METHOD=extractive

# Output length: "short" | "medium" | "long"
SUMMARY_LENGTH=medium

# Gemini model ID. Verify available IDs at:
#   https://ai.google.dev/gemini-api/docs/models
# Fast default (recommended for production):
GEMINI_MODEL_ID=gemini-2.5-flash-preview-05-20
# Higher-quality alternative (slower, higher cost):
# GEMINI_MODEL_ID=gemini-2.5-pro-preview-05-06

# ── Web server ───────────────────────────────────────────────────────────────

PORT=5000
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0

# Comma-separated allowed CORS origins. Use "*" only for development.
CORS_ORIGINS=*

# ── Rate limiting ─────────────────────────────────────────────────────────────

# Max API requests per IP per window
RATE_LIMIT_MAX=10
# Window duration in seconds
RATE_LIMIT_WINDOW=60

# ── Scraping ──────────────────────────────────────────────────────────────────

# HTTP request timeout in seconds
TIMEOUT_SCRAPING=30
# Number of retries on transient failures
MAX_RETRIES_SCRAPING=3

# ── Cache & output ────────────────────────────────────────────────────────────

CACHE_ENABLED=true
# Cache TTL in seconds (default 24 h)
CACHE_TTL=86400
OUTPUT_DIR=outputs

# ── Logging ───────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO

# ── Admin (optional) ──────────────────────────────────────────────────────────

# Set this to protect the /api/limpar-cache endpoint
# Leave empty to disable authentication on that endpoint
ADMIN_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection URL (SQLite used in dev when not set)
DATABASE_URL=postgresql://summarizer:summarizer@localhost:5432/summarizer

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis URL for cache and rate limiting (filesystem fallback when not set)
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Flower (Celery monitoring dashboard) ──────────────────────────────────────

# Basic auth for Flower dashboard (user:password)
FLOWER_BASIC_AUTH=admin:changeme

# ── JWT Authentication ────────────────────────────────────────────────────────

# JWT secret key (defaults to SECRET_KEY if not set)
JWT_SECRET_KEY=
# JWT v2 secret (used when rotating secrets without downtime)
# After rotation, both JWT_SECRET_KEY and JWT_SECRET_V2 are valid for verification
# for JWT_GRACE_PERIOD_SECONDS seconds. Use POST /api/admin/rotate-secret to rotate.
JWT_SECRET_V2=
# Admin credentials for JWT login endpoint
ADMIN_USER=admin
ADMIN_PASSWORD=
# Token expiry in hours (default: 24)
JWT_EXPIRES_HOURS=24

# ── CORS (update for production) ──────────────────────────────────────────────

# Dev: CORS_ORIGINS=*
# Prod: CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
CORS_ORIGINS=http://localhost:5000
